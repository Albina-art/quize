// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id        Int      @id @default(autoincrement())
  topic     String
  question  String
  hint      String?
  answer    String
  createdAt DateTime @default(now())

  trainerProgress TrainerQuestionProgress[]
}

model McqQuestion {
  id        Int         @id @default(autoincrement())
  topic     String
  question  String
  hint      String?
  createdAt DateTime    @default(now())
  options   McqOption[]
  progress  McqQuestionProgress[]
}

model MarkdownNote {
  id        String   @id @default(uuid())
  deviceId  String   @db.VarChar(128)
  title     String   @default("")
  body      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deviceId, updatedAt(sort: Desc)])
}

model McqQuestionProgress {
  id          Int         @id @default(autoincrement())
  deviceId    String      @db.VarChar(128)
  questionId  Int
  lastCorrect Boolean
  updatedAt   DateTime    @updatedAt
  question    McqQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([deviceId, questionId])
}

model TrainerQuestionProgress {
  id             Int      @id @default(autoincrement())
  deviceId       String   @db.VarChar(128)
  questionId     Int
  knewAnswer     Boolean
  updatedAt      DateTime @updatedAt
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([deviceId, questionId])
}

model McqOption {
  id         Int         @id @default(autoincrement())
  questionId Int
  question   McqQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean     @default(false)
  sortOrder  Int         @default(0)

  @@index([questionId])
}
