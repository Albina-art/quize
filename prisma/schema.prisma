// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique @db.VarChar(320)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notes           MarkdownNote[]
  mcqProgress     McqQuestionProgress[]
  trainerProgress TrainerQuestionProgress[]
}

model Question {
  id        Int      @id @default(autoincrement())
  topic     String
  question  String
  hint      String?
  answer    String
  createdAt DateTime @default(now())

  trainerProgress TrainerQuestionProgress[]
}

model McqQuestion {
  id        Int         @id @default(autoincrement())
  topic     String
  question  String
  hint      String?
  createdAt DateTime    @default(now())
  options   McqOption[]
  progress  McqQuestionProgress[]
}

model MarkdownNote {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("")
  body      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt(sort: Desc)])
}

model McqQuestionProgress {
  id          Int         @id @default(autoincrement())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId  Int
  lastCorrect Boolean
  updatedAt   DateTime    @updatedAt
  question    McqQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model TrainerQuestionProgress {
  id         Int      @id @default(autoincrement())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId Int
  knewAnswer Boolean
  updatedAt  DateTime @updatedAt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model McqOption {
  id         Int         @id @default(autoincrement())
  questionId Int
  question   McqQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean     @default(false)
  sortOrder  Int         @default(0)

  @@index([questionId])
}
